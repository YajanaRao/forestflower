      "dark": "syntax_comment",
      "light": "syntax_comment"
    },
    "syntaxKeyword": {
      "dark": "syntax_keyword",
      "light": "syntax_keyword"
    },
    "syntaxFunction": {
      "dark": "syntax_function",
      "light": "syntax_function"
    },
    "syntaxVariable": {
      "dark": "syntax_variable",
      "light": "syntax_variable"
    },
